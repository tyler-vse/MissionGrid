# Optional — force mock providers even when keys exist in UI / env (debugging)
# VITE_FORCE_MOCK_BACKEND=true
# VITE_FORCE_MOCK_MAPS=true

# Optional defaults for local dev (UI setup wizard overrides these per browser)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# Google Maps JavaScript API (browser key; restrict by HTTP referrer in Google Cloud)
# VITE_GOOGLE_MAPS_API_KEY=
